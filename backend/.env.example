# Copy this file to .env and fill in real values. Never commit the real .env file.

# PostgreSQL connection string
# Example for a local Docker Postgres (see docker-compose.yml):
DATABASE_URL="postgresql://kaizen:kaizen@localhost:5432/kaizen?schema=public"

# Long, random, secret string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-this-with-a-long-random-secret"

# How long a login session lasts
JWT_EXPIRES_IN="7d"

# The exact origin your frontend is served from (no trailing slash).
# Needed for CORS + secure cookies.
FRONTEND_URL="http://localhost:5173"

# "development" or "production". In production, auth cookies require HTTPS.
NODE_ENV="development"

# Port the API server listens on
PORT=4000

# Used once by prisma/seed.js to create the first admin account.
SEED_ADMIN_NAME="Admin"
SEED_ADMIN_EMAIL="admin@yourcompany.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
